<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Base.Theme.DentAssist"
        tools:targetApi="31"
        android:configChanges="uiMode"
        >

        <!-- Login - MAIN LAUNCHER -->
        <activity
            android:name=".Login"
            android:exported="true"
            android:theme="@style/Theme.DentAssist.Login">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".OwoPaymentActivity" />

        <!-- Register -->
        <activity
            android:name=".Register"
            android:exported="false"
            android:theme="@style/Theme.DentAssist.Login" />

        <!-- Forgot Password -->
        <activity
            android:name=".Forgot_Pass"
            android:exported="false"
            android:theme="@style/Theme.DentAssist.Login" />

        <!-- Main Activities with Drawer -->
        <activity android:name=".Dashboard" android:exported="false" />
        <activity android:name=".Profile" android:exported="false" />
        <activity android:name=".BookAppointment" android:exported="false" />
        <activity android:name=".Bills" android:exported="false" />
        <activity android:name=".MyTeeth" android:exported="false" />
        <activity android:name=".Points" android:exported="false" />
        <activity android:name=".Subscription" android:exported="false" />
        <activity android:name=".Referrals" android:exported="false" />
        <activity android:name=".ViewInvoiceActivity" />



    </application>

</manifest>