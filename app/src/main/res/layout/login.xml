<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- App Title -->
            <TextView
                android:id="@+id/tvAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DentAssist"
                android:textAppearance="@style/TextAppearance.DentAssist.Headline1"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smart Dental Clinic"
                android:textAppearance="@style/TextAppearance.DentAssist.Subtitle1"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:alpha="0.9"
                android:layout_marginTop="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvAppTitle" />

            <!-- Login Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLogin"
                style="@style/Widget.DentAssist.CardView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardElevation="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <!-- Register Prompt -->
                    <LinearLayout
                        android:id="@+id/layoutRegisterPrompt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Don't have an account? "
                            android:textAppearance="@style/TextAppearance.DentAssist.Body1"
                            android:textColor="@color/text_primary"
                             />

                        <TextView
                            android:id="@+id/tvRegisterLink"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Register"
                            android:textAppearance="@style/TextAppearance.DentAssist.Body1"
                            android:textColor="@color/primary"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <!-- Username Label -->
                    <TextView
                        android:id="@+id/tvUsernameLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Username"
                        android:textAppearance="@style/TextAppearance.DentAssist.Body1"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/layoutRegisterPrompt" />

                    <!-- Username Input Field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilUsername"
                        style="@style/Widget.DentAssist.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvUsernameLabel">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etUsername"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:maxLines="1"

                            android:textAppearance="@style/TextAppearance.DentAssist.Body1"
                            android:padding="12dp"
                            android:textColor="@color/text_primary"
                            android:textCursorDrawable="@color/cursor_black"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password Label -->
                    <TextView
                        android:id="@+id/tvPasswordLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Password"
                        android:textAppearance="@style/TextAppearance.DentAssist.Body1"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tilUsername" />

                    <!-- Password Input Field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPassword"

                        style="@style/Widget.DentAssist.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        app:endIconMode="password_toggle"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvPasswordLabel">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:textAppearance="@style/TextAppearance.DentAssist.Body1"
                            android:padding="12dp"
                            android:textColor="@color/text_primary"
                            android:textCursorDrawable="@color/cursor_black"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Remember Me -->
                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbRememberMe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Remember me"
                        android:textAppearance="@style/TextAppearance.DentAssist.Body1"
                        android:textColor="@color/text_secondary"
                        app:buttonTint="@color/primary"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tilPassword" />

                    <!-- Forgot Password -->
                    <LinearLayout
                        android:id="@+id/layoutForgotPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/cbRememberMe">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Forgot password? "
                            android:textAppearance="@style/TextAppearance.DentAssist.Body1"
                            android:textColor="@color/text_primary"
                             />

                        <TextView
                            android:id="@+id/tvForgotPasswordLink"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Click here"
                            android:textAppearance="@style/TextAppearance.DentAssist.Body1"
                            android:textColor="@color/primary"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <!-- Sign In Button -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnSignIn"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/button_primary_gradient"
                        android:text="Sign In"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textAllCaps="false"
                        android:stateListAnimator="@null"
                        android:elevation="4dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/layoutForgotPassword" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Footer -->
            <TextView
                android:id="@+id/tvFooter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="© 2026 DentAssist Smart Dental Clinic"
                android:textAppearance="@style/TextAppearance.DentAssist.Body2"
                android:textColor="@color/white"
                android:alpha="0.8"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardLogin" />

            <LinearLayout
                android:id="@+id/layoutFooterLinks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvFooter"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:id="@+id/tvFooterSignIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign in"
                    android:textAppearance="@style/TextAppearance.DentAssist.Body2"
                    android:textColor="@color/white"
                    android:alpha="0.8"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="·"
                    android:textColor="@color/white"
                    android:alpha="0.6" />

                <TextView
                    android:id="@+id/tvFooterRegister"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Register"
                    android:textAppearance="@style/TextAppearance.DentAssist.Body2"
                    android:textColor="@color/white"
                    android:alpha="0.8"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>