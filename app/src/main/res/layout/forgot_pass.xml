<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- App Title -->
            <TextView
                android:id="@+id/tvAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DentAssist"
                android:textAppearance="@style/TextAppearance.DentAssist.Headline1"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginTop="32dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smart Dental Clinic"
                android:textAppearance="@style/TextAppearance.DentAssist.Subtitle1"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:alpha="0.9"
                android:layout_marginTop="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvAppTitle" />

            <!-- Page Title -->
            <TextView
                android:id="@+id/tvPageTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password Reset"
                android:textAppearance="@style/TextAppearance.DentAssist.Subtitle1"
                android:textColor="@color/white"
                android:alpha="0.8"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvSubtitle" />

            <!-- Forgot Password Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardForgotPassword"
                style="@style/Widget.DentAssist.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardElevation="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvPageTitle">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <!-- Instruction Text -->
                    <TextView
                        android:id="@+id/tvInstruction"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Please enter your username. A reset link will be sent to your registered phone number via WhatsApp."
                        android:textAppearance="@style/TextAppearance.DentAssist.Body1"
                        android:textColor="@color/text_secondary"
                        android:gravity="center"
                        android:layout_marginBottom="16dp"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Username Label -->
                    <TextView
                        android:id="@+id/tvUsernameLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Username"
                        android:textAppearance="@style/TextAppearance.DentAssist.Body1"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvInstruction" />

                    <!-- Username Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilUsername"
                        style="@style/Widget.DentAssist.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        app:layout_constraintTop_toBottomOf="@id/tvUsernameLabel">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etUsername"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:maxLines="1"
                            android:textColor="@color/text_primary"
                            android:textCursorDrawable="@color/cursor_black"
                            android:textAppearance="@style/TextAppearance.DentAssist.Body1"
                            android:padding="12dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Reset Password Button -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnResetPassword"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/button_primary_gradient"
                        android:text="Reset Password"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textAllCaps="false"
                        android:stateListAnimator="@null"
                        android:elevation="4dp"
                        app:layout_constraintTop_toBottomOf="@id/tilUsername" />

                    <!-- Back to Login Button -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnBackToLogin"
                        style="@style/Widget.DentAssist.Button.Outline"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:text="Back to login"
                        android:textAllCaps="false"
                        app:layout_constraintTop_toBottomOf="@id/btnResetPassword" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Footer -->
            <TextView
                android:id="@+id/tvFooter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="© 2026 DentAssist Smart Dental Clinic"
                android:textAppearance="@style/TextAppearance.DentAssist.Body1"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:alpha="0.8"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardForgotPassword" />

            <LinearLayout
                android:id="@+id/layoutFooterLinks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvFooter"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:id="@+id/tvFooterSignIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign in"
                    android:textAppearance="@style/TextAppearance.DentAssist.Body1"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:alpha="0.8"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="·"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:alpha="0.6" />

                <TextView
                    android:id="@+id/tvFooterRegister"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Register"
                    android:textAppearance="@style/TextAppearance.DentAssist.Body1"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:alpha="0.8"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>